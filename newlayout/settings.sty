\newenvironment{betterList}{
    \begin{tblr}{
        width = \linewidth,
        colspec = {Q[0.02,l,t] Q[0.13,l,t] Q[0.85,l,t]},
        rows = {valign=t},
        rowsep = 4pt,
        column{1} = {leftsep=0pt},
        column{2} = {leftsep=0pt},
        column{3} = {leftsep=0pt,rightsep=0pt},
    }
}{
    \end{tblr}
}

\NewDocumentCommand{\exampleSentenceRemark}{O{}}{
    \ifblank{#1}{}{
        \begin{leftgraybox}
        \textbf{Remarque}{\hei 备注}

        #1
        \end{leftgraybox}
    }
}

\newenvironment{exampleSentence}[3]{%
    \llap{\bf{#1}\quad}#2\par
    {\kt #3}\\[-10pt]
    \noindent\textcolor{gray!50}{\rule{\linewidth}{0.4pt}}
    \begin{betterList}
}{%
    \end{betterList}
}

\newenvironment{vocabEntry}[3]{%
    {\large #1}\hspace{3pt}#2\hfill{\kt #3}\\[-10pt]
    \noindent\textcolor{gray!50}{\rule{\linewidth}{0.4pt}}
    \begin{betterList}
}{%
    \end{betterList}
}

\newcommand{\vocabMot}[3]{%
    #1\hspace{6pt}#2\\[-3pt]\hspace*{6pt}{\kt #3}%
}

\newenvironment{vocabRemark}{%
    \begin{leftgraybox}
    \textbf{Mots dérivés}{\hei 派生词}\vspace{4pt}\\
}{%
    \end{leftgraybox}
}

