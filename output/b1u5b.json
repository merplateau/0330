    "traslationPart": {
        "frenchToChinesePractice": {
            "frenchOriginalSentence": "Nous sommes en hiver et il neige aujourd'hui à Avignon. Alice est en retard parce que c'est son anniversaire: elle cherche sa montre partout, mais elle ne la trouve pas. À minuit, quelques jours après Noël, tout le monde dit «Bonne année!» et les enfants pensent déjà à leurs cadeaux du Jour de l'An. Quelle semaine formidable!",
            "chineseTranslation": "现在是冬天，阿维尼翁今天下雪了。Alice迟到了，因为今天是她的生日——她到处找表，却怎么也找不到。圣诞节后几天，午夜时分，大家齐声说“新年快乐！”，孩子们的心思早已飞向元旦的礼物。真是精彩的一周！",
            "fr2cnStrategy": "① «il neige» 为非人称句，译为“下雪了”，省去形式主语 il，符合中文习惯；② «être en retard» 译为“迟到了”，以动词短语替代法语形容词表语结构；③ «elle ne la trouve pas» 中的人称代词 la 指代 sa montre，翻译时显化为“表”，并以“怎么也……”强调否定语气，属增译；④ «à minuit, quelques jours après Noël» 时间状语组前置，符合汉语时间先于动作的叙述逻辑；⑤ «penser à leurs cadeaux» 译为“心思飞向礼物”，将介词短语转化为意象化动词短语，属词性转换与意译；⑥ «Quelle semaine formidable!» 感叹句保持感叹语气，formidable 译为“精彩的”，回避“了不起”的英语化表达。"
        },
        "chineseToFrenchPractice": [
            {
                "index": "1",
                "chineseOriginalSentence": "今天是她的生日，她非常高兴，因为她已经收到了礼物。",
                "frenchTranslation": "Aujourd'hui, c'est son anniversaire. Elle est très contente parce qu'elle a déjà reçu ses cadeaux.",
                "cn2frStrategy": "① “今天是她的生日”用 c'est + son anniversaire，注意主语用 c'est 而非 elle est；② “非常高兴”用 très contente，形容词需与主语 elle 性数一致（阴性加 e）；③ “已经收到了”需要复合过去时 a reçu，过去分词 reçu 来自不规则动词 recevoir；④ “因为”用 parce que，引导原因从句。"
            },
            {
                "index": "2",
                "chineseOriginalSentence": "在法国，十二月真的是一个节日月份，尤其是圣诞节那一周。",
