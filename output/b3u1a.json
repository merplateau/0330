    "traslationPart": {
        "frenchToChinesePractice": {
            "frenchOriginalSentence": "Les Français ont l’assiette légère. Quoique les Français aiment manger, le temps de l’assiette lourde est fini. À cause de l’apparition des familles nucléaires, on prend moins de repas à domicile. Aujourd’hui, une femme ne passe que quarante minutes dans la cuisine, à l’aide du réfrigérateur et du four moderne.",
            "chineseTranslation": "法国人饮食清淡。尽管法国人喜欢美食，但油腻饮食的时代已经结束。由于核心家庭的出现，人们在家用餐的次数减少。如今，借助冰箱和现代烤箱，一位女性在厨房只待四十分钟。",
            "fr2cnStrategy": "① “ont l’assiette légère” 意译为“饮食清淡”，避免直译“有轻的盘子”。② “Quoique” 让步从句译为“尽管……但……”，添加“但”强化转折。③ “À cause de” 表示负面原因，直接译为“由于”。④ “ne...que” 译为“只”，准确传达限定。⑤ “à l’aide de” 译为“借助”，符合中文表达。⑥ 将长句拆分为多个短句，符合中文流水句习惯。"
        },
        "chineseToFrenchPractice": [
            {
                "index": 1,
                "chineseOriginalSentence": "尽管法国人喜欢美食，但他们现在更倾向于清淡饮食。",
                "frenchTranslation": "Quoique les Français aiment manger, ils préfèrent désormais l’assiette légère.",
                "cn2frStrategy": "① 让步从句用 Quoique + 虚拟式 aiment。② “倾向于”译为 préfèrent。③ “清淡饮食”用固定搭配 l’assiette légère。"
            },
            {
                "index": 2,
                "chineseOriginalSentence": "由于工作繁忙，她每天只在厨房待半小时。",
                "frenchTranslation": "À cause de son travail chargé, elle ne reste qu’une demi-heure dans la cuisine par jour.",
                "cn2frStrategy": "① “由于”用 À cause de（中性/负面原因）。② “只……”用 ne...que 结构。③ “半小时”译为 une demi-heure。"
            },
            {
                "index": 3,
                "humanExplanation": "本句考察动词 consacrer 的用法以及时间表达。",
                "chineseOriginalSentence": "她把大量时间用于工作，而不是做饭。",
                "frenchTranslation": "Elle consacre beaucoup de temps au travail au lieu de faire la cuisine.",
                "cn2frStrategy": "① “把时间用于”用 consacrer du temps à。② “而不是”用 au lieu de。③ “做饭”译为 faire la cuisine。"
            },
            {
                "index": 4,
                "chineseOriginalSentence": "借助现代家电，人们可以轻松准备健康菜肴。",
                "frenchTranslation": "À l’aide des appareils électroménagers modernes, on peut préparer facilement des plats sains.",
                "cn2frStrategy": "① “借助”用 à l’aide de。② “家电”译为 appareils électroménagers。③ “健康菜肴”用 plats sains，形容词后置。④ “轻松”副词 facilement 置于动词后。"
            }
        ]
    }
