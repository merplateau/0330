    "traslationPart": {
        "frenchToChinesePractice": {
            "frenchOriginalSentence": "Je sais que vous êtes un Père Noël moderne, je préfère donc passer ma commande sur Internet. Les enfants comme leurs parents attendent avec impatience leurs cadeaux, mais nous n'avons pas assez d'argent pour acheter tout ce que nous désirons, alors je compte sur vous ! Il y a du champagne devant la cheminée, c'est moi qui vous invite.",
            "chineseTranslation": "我知道您是一位与时俱进的圣诞老人，所以我宁愿在网上下单。孩子们和家长们一样，都迫不及待地盼着收礼物，可我们没有足够的钱买下所有心仪的东西，因此全靠您了！壁炉前备有香槟，是我来招待您。",
            "fr2cnStrategy": "① je préfère donc 中的 donc 译为“所以”，放在分句之间，体现逻辑顺承；② Les enfants comme leurs parents 的比较结构转为“孩子们和家长们一样，都……”，符合汉语并列表达习惯；③ tout ce que nous désirons 拆解为“所有心仪的东西”，将关系从句转为定语，避免生硬的“所有我们想要的”；④ alors je compte sur vous 的“compter sur”意译为“全靠您了”，保留口语语气；⑤ c'est moi qui vous invite 强调句型，译为“是我来招待您”，保留强调焦点。"
        },
        "chineseToFrenchPractice": [
            {
                "index": "1",
                "chineseOriginalSentence": "我宁愿在网上下单，因为邮寄太慢了。",
                "frenchTranslation": "Je préfère passer ma commande sur Internet, car le courrier est trop lent.",
                "cn2frStrategy": "① “宁愿”用 préférer + 不定式；② “在网上下单”用固定搭配 passer une commande sur Internet；③ “因为”选用 car（书面语，语气肯定），而非 parce que；④ “太慢”用 trop + 形容词结构。"
            },
            {
                "index": "2",
                "chineseOriginalSentence": "他们迫不及待地等待着圣诞礼物。",
                "frenchTranslation": "Ils attendent avec impatience leurs cadeaux de Noël.",
                "cn2frStrategy": "① “迫不及待地”用固定搭配 avec impatience 作方式状语，置于动词之后；② “等待”用 attendre（直接及物，不加介词）；③ “圣诞礼物”用 cadeaux de Noël，注意名词复数形式。"
            },
            {
                "index": "3",
                "chineseOriginalSentence": "他现在不得不步行去上学，他很难过。",
                "frenchTranslation": "Il est maintenant obligé d'aller en classe à pied. Il est triste.",
                "cn2frStrategy": "① “不得不”用 être obligé de + 不定式；② “步行”用固定短语 à pied（不用介词 en）；③ “去上学”用 aller en classe；④ “难过”用 être triste（表语形容词结构），分两句表达，符合法语简洁倾向。"
            },
            {
                "index": "4",
                "chineseOriginalSentence": "壁炉前是我为您准备的香槟，是我来招待您的。",
                "frenchTranslation": "Il y a du champagne pour vous devant la cheminée, c'est moi qui vous invite.",
                "cn2frStrategy": "① “壁炉前有香槟”用存在句 il y a + 部分冠词 du champagne；② 地点状语 devant la cheminée 置于宾语之后；③ “是我来招待您”用强调句型 c'est moi qui + 动词（关系从句动词用第三人称单数 invite，非 j'invite）。"
            }
        ]
    }
