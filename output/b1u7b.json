    "traslationPart": {
        "frenchToChinesePractice": {
            "frenchOriginalSentence": "Louise et Nathalie passent leurs vacances d'été en Bretagne. Après trois heures de voyage en train, elles continuent le voyage à vélo et vont passer la nuit dans une auberge de jeunesse au bord de la mer. Quelquefois, elles dînent dans un petit restaurant en même temps qu'elles écoutent la radio. Ce sont deux jeunes filles très différentes, mais elles s'amusent bien ensemble.",
            "chineseTranslation": "露易丝和娜塔莉在布列塔尼度过了她们的暑假。乘坐三小时火车之后，她们骑自行车继续旅程，打算在海边的一家青年旅舍过夜。有时，她们边听收音机边在一家小餐厅吃晚饭。她们是两个性格迥异的女孩，但在一起总能玩得很开心。",
            "fr2cnStrategy": "① après trois heures de voyage en train 处理为时间状语前置，译为”乘坐三小时火车之后”，调整语序符合中文习惯；② continuer le voyage à vélo 中，à vélo 译为”骑自行车”，通过增译动作主体使译文更自然；③ en même temps qu'elles écoutent la radio 采用”边……边……”结构，将法语的时间从句转换为汉语常用的并列动作表达；④ très différentes 译为”性格迥异”，属于词性转换与增译，避免”非常不同”的生硬直译；⑤ s'amusent bien ensemble 译为”在一起总能玩得很开心”，增译”总能”以体现习惯性动作的语气。"
        },
        "chineseToFrenchPractice": [
            {
                "index": "1",
                "chineseOriginalSentence": "这是我第一次骑自行车去海边旅行。",
                "frenchTranslation": "C'est la première fois que je voyage à vélo jusqu'au bord de la mer.",
                "cn2frStrategy": "① ”这是第一次……”用固定句型 c'est la première fois que + 陈述式现在时；② ”骑自行车”用 à vélo，区别于乘坐交通工具用 en；③ ”去海边”用 jusqu'au bord de la mer，jusqu'à 表示目的地方向。"
            },
            {
                "index": "2",
                "chineseOriginalSentence": "她们有时一起在小旅馆吃饭，同时聊天。",
                "frenchTranslation": "Quelquefois, elles dînent ensemble dans une petite auberge et parlent en même temps.",
                "cn2frStrategy": "① ”有时”用 quelquefois，置于句首；② ”一起”用 ensemble，置于动词后；③ ”同时”用固定表达 en même temps，置于句末；④ ”聊天”用 parler（不及物），不加宾语时直接使用。"
            },
            {
                "index": "3",
                "chineseOriginalSentence": "他是一位非常出色的钢琴家，对音乐非常感兴趣。",
                "frenchTranslation": "C'est un très bon pianiste et il s'intéresse beaucoup à la musique.",
                "cn2frStrategy": "① ”是一位……”用表语句型 c'est un...；② ”对……感兴趣”用代词式动词固定搭配 s'intéresser à，介词不可省略；③ ”非常”修饰动词时用 beaucoup，不用 très（très 修饰形容词/副词）。"
            },
            {
                "index": "4",
                "chineseOriginalSentence": "尽管她们两个人性格各不相同，但总是在一起玩得很开心。",
                "frenchTranslation": "Bien qu'elles soient très différentes, elles s'amusent toujours bien ensemble.",
                "cn2frStrategy": "① ”尽管……”用 bien que 引导让步状语从句，从句动词须用虚拟式现在时 soient（être 的虚拟式）；② ”性格各不相同”译为 très différentes，形容词与主语 elles（阴性复数）保持性数一致；③ ”总是”用 toujours，置于动词 s'amusent 后；④ ”在一起玩得开心”用 s'amuser bien ensemble。"
