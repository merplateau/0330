{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./section1.schema.json",
  "title": "Section 1 Sentences",
  "type": "object",
  "required": [
    "sentences"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "sentences": {
      "type": "array",
      "description": "课文重难句列表",
      "items": {
        "$ref": "#/$defs/sentenceEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "sentenceEntry": {
      "type": "object",
      "required": [
        "index",
        "sentence",
        "translatedSentence",
        "sentenceStructure",
        "grammarAnalysis",
        "examKeyPoints",
        "commonMistakes"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "description": "序号，从1开始的正整数"
        },
        "sentence": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "完整引用课文原句，按课文出现顺序排列"
        },
        "translatedSentence": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "用自然流畅的中文表达，不要逐词硬译；优先保证译文读起来像正常的中文句子，必要时可调整语序、增减词语、转换词性，只要语义忠实即可"
        },
        "sentenceStructure": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "拆解为「主语 — 谓语 — 宾语/补语/状语」"
        },
        "grammarAnalysis": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "标明涉及的时态、语态、语气、句型"
        },
        "examKeyPoints": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "指出该句涉及的考试重点"
        },
        "commonMistakes": {
          "$ref": "#/$defs/nonEmptyString",
          "description": "指出学生常见的理解或翻译错误"
        }
      },
      "additionalProperties": false
    }
  }
}
